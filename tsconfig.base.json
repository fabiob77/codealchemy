{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["ES2017"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@codealchemy/common": ["./common/dist/index.d.ts"],
      "@codealchemy/sdk": ["./sdk/dist/index.d.ts"],
      "@codealchemy/agents": ["./agents/dist/index.d.ts"],
      "@codealchemy/cli": ["./cli/dist/index.d.ts"]
    }
  }
}
